# ============================================================
# WARREN AI LAB — STACK CONFIG
# Copy this file to .env and fill in the blanks:   cp .env.example .env
# .env is gitignored — NEVER commit it. The setup script fills the secrets for you.
# This .env is for THIS stack only; it is separate from the repo-root .env.
# ============================================================

# ============================================================
# GENERAL
# ============================================================
# IANA timezone for logs + (later) n8n schedules. e.g. Asia/Dubai, Europe/London, Africa/Johannesburg
TZ=Asia/Dubai

# Which extra services to run. Blank = AI-only v1 (ollama + open-webui).
# Comma-separate any of: automation (n8n + postgres), vector (qdrant), proxy (caddy).
#   e.g.  COMPOSE_PROFILES=automation        or   COMPOSE_PROFILES=automation,vector
COMPOSE_PROFILES=

# ============================================================
# PORTS (host side — change only if something already uses them on the box)
# ============================================================
OPEN_WEBUI_PORT=3000
# OLLAMA_PORT=11434     # only used if you uncomment the ollama host port in docker-compose.yml
# N8N_PORT=5678         # used with the "automation" profile
# QDRANT_PORT=6333      # used with the "vector" profile

# ============================================================
# MODELS — the portability lever. Change these per hardware tier, then run pull-models.
#   MINI   (N97 / CPU-only, <=12 GB) : DEFAULT_MODEL=llama3.2:3b      (fallback: gemma2:2b)
#   SMALL  (16-32 GB CPU)            : DEFAULT_MODEL=qwen2.5:7b
#   MEDIUM (32-64 GB / entry GPU)    : DEFAULT_MODEL=qwen2.5:14b      EMBED_MODEL=mxbai-embed-large
#   LARGE  (GPU server)              : DEFAULT_MODEL=qwen2.5:32b      EMBED_MODEL=mxbai-embed-large
# ============================================================
DEFAULT_MODEL=llama3.2:3b
EMBED_MODEL=nomic-embed-text
# How long Ollama keeps a model in RAM after last use (frees RAM on the mini PC)
OLLAMA_KEEP_ALIVE=5m

# ============================================================
# OPEN WEBUI (AI UI + document knowledge base)
# ============================================================
# Signs session tokens. Long random string. Generate:  openssl rand -hex 32
WEBUI_SECRET_KEY=your_value_here
# Leave this TRUE for the very first run so you can create your admin account (the first
# account becomes admin). Once you're in, set it to false and run `docker compose up -d`
# again to lock sign-ups so nobody else can register.
ENABLE_SIGNUP=true
# Vector store: chroma (built-in, best for the mini PC) | qdrant (requires the "vector" profile)
VECTOR_DB=chroma

# ============================================================
# AUTOMATION — n8n + Postgres  (inactive until COMPOSE_PROFILES includes "automation")
# Fill these in before enabling the automation profile.
# ============================================================
# Encryption key for n8n stored credentials — MUST stay constant or creds can't decrypt. openssl rand -hex 32
N8N_ENCRYPTION_KEY=your_value_here
N8N_HOST=localhost
N8N_PROTOCOL=http
# Public webhook base URL — change to the box's LAN IP / tailnet name / domain for external triggers.
N8N_WEBHOOK_URL=http://localhost:5678/

POSTGRES_DB=warrenlab
POSTGRES_USER=warrenlab
# Strong password. Generate:  openssl rand -hex 24
POSTGRES_PASSWORD=your_value_here
